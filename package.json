{
  "name": "hacktrack-eu",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "prebuild": "npm run format && npm run knip",
    "build": "next build --turbopack",
    "postbuild": "next-sitemap",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "knip": "knip",
    "sitemap": "next-sitemap",
    "update-themes": "node scripts/update-themes.js && npm run format",
    "update": "npx npm-check-updates -u && npm install && npm run update-themes",
    "reinstall": "rm -rf node_modules package-lock.json .next && npm install"
  },
  "dependencies": {
    "@octokit/rest": "^22.0.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@supabase/supabase-js": "^2.100.0",
    "add-to-calendar-button-react": "^2.13.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.577.0",
    "next": "16.2.1",
    "next-sitemap": "^4.2.3",
    "p-limit": "^7.3.0",
    "react": "19.2.4",
    "react-country-flag": "^3.1.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "tailwind-merge": "^3.5.0",
    "twitter-api-v2": "^1.29.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "^10.1.0",
    "eslint-config-next": "16.2.1",
    "knip": "^6.0.4",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2"
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
