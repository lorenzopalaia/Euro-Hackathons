{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "app/**/*.{js,ts,tsx}",
    "lib/**/*.ts",
    "types/**/*.ts",
    "contexts/**/*.tsx",
    "components/**/*.tsx"
  ],
  "project": ["**/*.{js,ts,tsx}", "!node_modules/**", "!.next/**"],
  "ignore": ["next-sitemap.config.js"],
  "ignoreDependencies": [
    "eslint",
    "@eslint/eslintrc",
    "eslint-config-next",
    "tailwindcss",
    "prettier-plugin-tailwindcss",
    "tw-animate-css",
    "postcss"
  ],
  "ignoreBinaries": ["npm-check-updates"],
  "next": true,
  "postcss": true,
  "prettier": true,
  "typescript": true,
  "eslint": false,
  "tailwind": true
}
